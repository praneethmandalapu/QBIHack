{
  "version": "1.0.0",
  "cancer": "breast",
  "description": "Genomic risk handoff for breast visualization and OncoPulse UI. Join key matches philip-chandan cohort tcga_id.",
  "patient_id_column": "patient_id",
  "source_model": "breast-cancer-sim/oncopulse.py",
  "source_cohort": "simulation-vinesh-philip-chandan/philip-chandan/cohort/cohort.json",
  "growth_multiplier": {
    "lo": 0.8,
    "hi": 1.8,
    "formula": "lo + (hi - lo) * risk"
  },
  "files": {
    "patients": "patients.csv"
  },
  "patients_csv_columns": [
    "patient_id",
    "subtype",
    "pam50",
    "risk",
    "growth_multiplier",
    "cohort_role",
    "er_status"
  ],
  "regenerate": "breast-cancer-sim/.venv/bin/python visualization-jasim/risk/export_risk.py"
}
