{
  "version": "1.1.0",
  "description": "Philip-Chandan ↔ Vinesh array handoff contract. PDE input uses napari expert mask (aligned_bbox) published to segmentations/, brain-parity prep pipeline.",
  "spike_patient": {
    "tcga_id": "TCGA-AR-A1AX",
    "subtype": "Luminal A",
    "study_date": "2002-09-12",
    "slug": "luminal_a_TCGA-AR-A1AX_baseline"
  },
  "raw_extract": {
    "producer": "philip-chandan",
    "output_dir": "data/processed/raw-extract-philip-chandan/{tcga_id}",
    "basename": "{timepoint}",
    "axis_order": ["Z", "Y", "X"],
    "dtype": "float32",
    "normalize": false,
    "value_semantics": {
      "description": "Raw MR scanner intensity; not scaled to [0, 1]"
    },
    "required_metadata_fields": [
      "contract_version",
      "slug",
      "tcga_id",
      "subtype",
      "study_date",
      "source_dicom_dir",
      "shape",
      "dtype",
      "spacing_mm",
      "segmentation_path"
    ]
  },
  "pde_input": {
    "producer": "vinesh",
    "output_dir": "data/processed/pde-input-vinesh/{tcga_id}/g{grid_size}",
    "basename": "{timepoint}",
    "default_grid_size": 64,
    "grid_size_options": [64],
    "axis_order": ["Z", "Y", "X"],
    "dtype": "float32",
    "max_shape": [64, 64, 64],
    "target_spacing_mm": [1.0, 1.0, 1.0],
    "value_range": [0.0, 1.0],
    "background_value": 0.0,
    "tumor_burden_rule": "values strictly greater than background_value",
    "segmentation": {
      "method": "expert_mask",
      "notes": "Napari aligned_bbox mask published to data/processed/segmentations/{slug}_mask.nii.gz; resample to target grid. No Otsu fallback."
    },
    "required_metadata_fields": [
      "contract_version",
      "slug",
      "source_raw_extract",
      "source_segmentation",
      "shape",
      "dtype",
      "spacing_mm",
      "value_semantics"
    ]
  },
  "solver": {
    "timesteps": 50,
    "dt": 0.1,
    "default_params": {
      "risk_multiplier": 1.2
    }
  }
}
