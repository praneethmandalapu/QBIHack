{
  "version": "rev2-ucsf-no-rc",
  "description": "Brain imaging cohort from UCSF-LPTDG. rev2 expands the no-resection-cavity subset (14 genomics-eligible patients total; 12 added here plus spike 100002 and demo 100118). Primary pair: 100002 (IDH-mut stable) vs 100118 (IDH-WT GBM aggressive growth).",
  "preferred_datasets": [
    "ucsf_longitudinal_glioma",
    "mu_glioma_post",
    "lumiere"
  ],
  "data_root": "brain-cancer-sim/data/raw/ucsf_alptdg/  (gitignored; extract from UCSF portal)",
  "segmentation_label_scheme": {
    "1": "NCR (necrotic core)",
    "2": "SNFH (edema / non-enhancing FLAIR hyperintensity)",
    "3": "ET (enhancing tumor)",
    "4": "RC (resection cavity)",
    "WT": "whole tumor = labels 1+2+3",
    "TC": "tumor core = labels 1+2"
  },
  "available_sequences_per_timepoint": [
    "t1",
    "t1ce",
    "t2",
    "flair",
    "seg"
  ],
  "genomics_handoff": "Per-patient idh_status/grade/mgmt are the bridge to the brain risk model (see brain-cancer-sim/models-praneeth/). IDH-WT + high grade -> high growth_multiplier; IDH-mut -> low.",
