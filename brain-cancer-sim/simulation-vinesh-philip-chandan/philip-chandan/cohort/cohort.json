{
  "version": "rev1-ucsf",
  "description": "Brain imaging cohort from the UCSF Longitudinal Postoperative Diffuse Glioma dataset (UCSF-LPTDG). Primary pair contrasts an aggressive IDH-WT glioblastoma (grows) vs an indolent IDH-mutant lower-grade glioma (stable/shrinks) \u2014 the genomics->growth seam.",
  "data_root": "brain-cancer-sim/data/raw/ucsf_glioma/  (gitignored; extract from UCSF zip)",
  "segmentation_label_scheme": {
    "1": "NCR (necrotic core)",
    "2": "SNFH (edema / non-enhancing FLAIR hyperintensity)",
    "3": "ET (enhancing tumor)",
    "4": "RC (resection cavity)",
    "WT": "whole tumor = labels 1+2+3",
    "TC": "tumor core = labels 1+2"
  },
  "available_sequences_per_timepoint": [
    "t1",
    "t1ce",
    "t2",
    "flair",
    "seg"
  ],
  "genomics_handoff": "Per-patient idh_status/grade/mgmt are the bridge to the brain risk model (see brain-cancer-sim/models-praneeth/). IDH-WT + high grade -> high growth_multiplier; IDH-mut -> low.",
